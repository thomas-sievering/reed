{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "reed",
  "identifier": "com.reed.app",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "reed",
        "width": 900,
        "height": 700,
        "minWidth": 400,
        "minHeight": 300,
        "dragDropEnabled": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "fileAssociations": [
      {
        "ext": [
          "md",
          "markdown"
        ],
        "mimeType": "text/markdown",
        "name": "Markdown",
        "description": "Markdown document"
      }
    ]
  }
}
